# PostgreSQL Database Configuration
PG_DB_HOST=localhost
PG_DB_PORT=5432
PG_DB_NAME=newzelador_db
PG_DB_USER=your_db_user
PG_DB_PASSWORD=your_db_password

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
# Optional: leave empty when Redis does not require authentication
REDIS_PASSWORD=

# WhatsApp Bot Configuration
# Minimum delay (in seconds)
MIN_DELAY=15
# Maximum delay (in seconds)
MAX_DELAY=15
# Jitter range (in seconds) applied as [-DELAY_JITTER, +DELAY_JITTER]
DELAY_JITTER=3

# Maximum time (ms) per WhatsApp API call
CALL_TIMEOUT_MS=15000

# Logging
# Log level for the app: trace|debug|info|warn|error|fatal
LOG_LEVEL=info
# Optional: log level for Baileys internals: trace|debug|info|warn|error|fatal
BAILEYS_LOG_LEVEL=fatal
# Optional: environment mode. When set to "production" logs are JSON; otherwise pretty
# printing is enabled if output is a TTY.
NODE_ENV=development

# Kuma Uptime Url
UPTIME_URL=
# Interval between uptime pings while the worker is healthy
UPTIME_INTERVAL_SECONDS=60
# Idle loop delay when running only event-driven modes like --moderation/--auth
IDLE_LOOP_DELAY_SECONDS=30

# Telegram Bot (optional notifications)
# Bot token from BotFather
TELEGRAM_BOT_TOKEN=
# Chat ID to receive failure alerts (addition and removal)
TELEGRAM_FAILURES_CHAT_ID=
# Chat ID to receive moderation flagged logs
TELEGRAM_MODERATIONS_CHAT_ID=

# Moderation
# Toggle link invite deletion (true|false)
ENABLE_LINK_MODERATION=true
# Toggle content moderation + Telegram reporting (true|false)
ENABLE_CONTENT_MODERATION=false
# OpenAI API key (required if ENABLE_CONTENT_MODERATION=true)
OPENAI_API_KEY=
# Optional: exact group name that receives the first-contact message and audio
FIRST_CONTACT_GROUP_NAME=
# WhatsApp phone number for pairing (include country code, e.g. 5511999999999)
PAIRING_PHONE=
# Baileys auth files are stored locally in the ignored `auth/` directory

# Tooling (optional; used by src/tools/addAdminToAllGroups.ts defaults)
PROMOTE_DELAY_SECONDS=2
RECONNECT_RETRIES=2
RECONNECT_DELAY_SECONDS=3
